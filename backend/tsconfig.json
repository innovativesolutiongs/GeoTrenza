{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true, // ✅ required
    "emitDecoratorMetadata": true, // ✅ required
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "rootDir": "./src",
  },
  "include": [
    "src/**/*",
    "src/types/express-session.d.ts"
  ],
  "typeRoots": [
    "./node_modules/@types",
    "./src/types"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}